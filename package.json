{
  "name": "prominence",
  "version": "0.1.0",
  "description": "Desktop HUD that tracks your Claude Code usage in real time",
  "main": "dist/main/index.js",
  "author": "3stankyle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/3stankyle/prominence.git"
  },
  "scripts": {
    "start": "tsc && electron .",
    "build": "tsc && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.prominence.usage-hud",
    "productName": "Prominence",
    "files": [
      "dist/**/*",
      "src/renderer/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
